classDiagram
    class Owner {
        +name: str
        +email: str
        +available_start: str
        +available_end: str
        +add_pet(pet)
        +add_task(task)
    }

    class Pet {
        +name: str
        +species: str
        +age: int
        +owner: Owner
        +add_task(task)
    }

    class CareTask {
        +title: str
        +duration_minutes: int
        +priority: str
        +preferred_time: str
        +is_complete: bool
        +mark_complete()
    }

    class Scheduler {
        +generate_daily_plan(owner, tasks)
        +sort_tasks(tasks)
        +fit_tasks_into_day(tasks, owner)
        +explain_plan(plan)
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" CareTask : needs
    Scheduler ..> Owner : uses availability
    Scheduler ..> CareTask : evaluates
